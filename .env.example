# AdMonitor Pro Environment Variables

# Database Configuration (Required for Production)
# Get this from Neon, Supabase, or your PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Node Environment
NODE_ENV=production

# Optional: Gemini API Key (if using AI features)
# GEMINI_API_KEY=your_api_key_here

# Optional: Override bundled offline Vosk model archive
# Defaults to /models/vosk-model-small-en-us-0.15.tar.gz
# VITE_VOSK_MODEL_URL=/models/vosk-model-small-en-us-0.15.tar.gz

# Optional: Vercel KV (if using Vercel KV instead of database)
# KV_URL=https://...

# Optional: For Email Notifications
# SENDGRID_API_KEY=your_sendgrid_key
# NOTIFICATION_EMAIL=your_email@example.com
