{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc -b",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "cap:init": "cap init \"AdMonitor Pro\" com.admonitor.pro --web-dir dist",
    "cap:sync": "cross-env CAPACITOR=true vite build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "build:mobile": "npm run cap:sync"
  },
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capawesome-team/capacitor-android-battery-optimization": "^6.0.0",
    "@capawesome-team/capacitor-android-foreground-service": "^6.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^2.2.7",
    "sonner": "^2.0.7",
    "vite": "^6.2.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.admonitor.pro",
    "productName": "AdMonitor Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
